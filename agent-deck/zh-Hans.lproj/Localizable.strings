"agent.description.general-purpose" = "通用 Agent，用于复杂问题研究、代码搜索和多步骤任务执行。";
"agent.description.Explore" = "快速只读搜索 Agent，用于按模式查找文件、grep 符号/关键词，或定位定义和引用。";
"agent.description.Plan" = "软件架构规划 Agent，用于设计实现策略、识别关键文件并权衡架构取舍。";
"agent.description.advisor" = "战略架构和产品顾问，用于对计划、取舍、产品方向和风险给出只读第二意见。";
"agent.description.artifact-code-reviewer" = "独立的产物代码审查 Agent。按代码质量、代码库适配度和可执行性审查最终产物中的代码块，并输出分级问题。";
"agent.description.artifact-coverage-reviewer" = "独立的产物覆盖审查 Agent。检查 Verification Notes 与 Precedents & Lessons 是否落实到成功标准或代码中。";
"agent.description.artifacts-analyzer" = "研究版 codebase-analyzer，用于深入分析某个研究主题。";
"agent.description.artifacts-locator" = "查找 .rpiv/artifacts/ 中相关文档，用于发现既有研究、设计、计划或审查。";
"agent.description.claim-verifier" = "对抗式发现验证 Agent。把输入声明与仓库真实状态核对，并标记 Verified / Weakened / Falsified。";
"agent.description.codebase-analyzer" = "分析代码库实现细节，用于深入了解特定组件。";
"agent.description.codebase-locator" = "定位与功能或任务相关的文件、目录和组件，适合替代多次 grep/find/ls。";
"agent.description.codebase-pattern-finder" = "查找相似实现、用法示例和可复用模式，并返回具体代码示例。";
"agent.description.diff-auditor" = "只输出行级证据的补丁审计 Agent。按给定 surface-list 枚举 diff 中匹配项，不给叙述或严重级别。";
"agent.description.integration-scanner" = "扫描某组件/区域的连接关系：入站引用、出站依赖、配置注册和事件订阅。";
"agent.description.peer-comparator" = "同级不变量比较 Agent。对比新文件与同类 peer，标记 Mirrored / Missing / Diverged / Intentionally-absent。";
"agent.description.precedent-locator" = "查找 git 历史中的相似改动、影响范围、后续修复和相关经验。";
"agent.description.reviewer" = "只读审查 Agent，关注代码、配置、文档和工作流变更的正确性、安全性、可维护性、UX 与回归风险。";
"agent.description.scope-tracer" = "追踪研究范围的 Agent。围绕锚点词扫描代码库、阅读关键文件，并给出发现摘要和边界问题。";
"agent.description.slice-verifier" = "分片级对抗验证 Agent。审查刚生成的切片是否符合共享契约、既有切片和约束，捕捉跨切片漂移。";
"agent.description.test-case-locator" = "查找 .rpiv/test-cases/ 中已有手工测试用例，提取元数据并报告覆盖情况。";
"agent.description.web-search-researcher" = "联网研究 Agent，用于查找较新或需要网页信息的问题，并整理答案。";
"agent.description.cli-explore-agent" = "只读代码探索 Agent，结合 Bash 与 CLI 语义分析输出结构化结果。";
"agent.description.cross-role-reviewer" = "跨角色审查 Agent，对比 brainstorm 会话中的角色分析，发现冲突、缺口和协同点。";
"agent.description.impeccable-agent" = "自动化 UI/设计执行 Agent，用于 audit、polish、harden、layout、typeset 等非交互设计操作。";
"agent.description.role-design-author" = "角色设计作者 Agent，为 brainstorm 会话生成多文件角色分析。";
